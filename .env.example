# Copy this file to .env for local development (never commit .env to git)
SECRET_KEY=your-secret-key-here

# Local MySQL (only used when DATABASE_URL is not set)
MYSQLUSER=root
MYSQLPASSWORD=Root@123
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQL_DATABASE=hypertension_db

# Set this when connecting to an external/cloud database directly
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
